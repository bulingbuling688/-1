{
  "webhook_url": "https://YOUR_N8N_HOST/webhook/ingest-news",
  "ai": {
    "webhook_url": "https://YOUR_N8N_HOST/webhook/frontend-ai-article",
    "timeout_sec": 120,
    "model": "gpt-4.1-mini"
  },
  "github_storage": {
    "enabled": false,
    "repo": "YOUR_GITHUB_NAME/YOUR_REPO",
    "branch": "main",
    "path_prefix": "generated_articles",
    "token_env": "GITHUB_TOKEN",
    "local_backup_dir": "generated_articles"
  },
  "state_db": "collector_state.sqlite3",
  "fetch_timeout_sec": 15,
  "content_fetch": {
    "enabled": true,
    "timeout_sec": 12,
    "max_chars": 6000,
    "user_agent": "Mozilla/5.0 (NewsCollector)"
  },
  "delivery": {
    "batch_size": 5,
    "max_attempts": 8,
    "max_retries": 5,
    "retry_backoff_sec": 2,
    "timeout_sec": 120
  },
  "sources": [
    {
      "type": "hn_topstories",
      "enabled": true,
      "name": "hackernews",
      "limit": 20,
      "topstories_url": "https://hacker-news.firebaseio.com/v0/topstories.json",
      "item_url_template": "https://hacker-news.firebaseio.com/v0/item/{id}.json"
    },
    {
      "type": "rss",
      "enabled": true,
      "name": "openai_news",
      "url": "https://openai.com/news/rss.xml",
      "limit": 20
    },
    {
      "type": "anthropic_news",
      "enabled": true,
      "name": "anthropic_news",
      "url": "https://www.anthropic.com/news",
      "limit": 20
    },
    {
      "type": "rss",
      "enabled": false,
      "name": "bbc_world",
      "url": "https://feeds.bbci.co.uk/news/world/rss.xml",
      "limit": 20
    },
    {
      "type": "raingou",
      "enabled": false,
      "name": "raingou",
      "base_url": "https://news.raingou.com/api/s",
      "source_ids": [
        "github-trending-today",
        "hackernews",
        "wallstreetcn-news",
        "36kr"
      ]
    }
  ]
}
