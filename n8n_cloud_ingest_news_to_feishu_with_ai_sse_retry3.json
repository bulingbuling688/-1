                  {
                      "parameters":  {
                                         "jsCode":  "const original = $node[\u0027Webhook Ingest\u0027].json.body?.items || $node[\u0027Webhook Ingest\u0027].json.items || [];\n\n// For SSE-like responses, collect all delta.content text.\nconst rawBody = String($node[\u0027LLM Analyze (SSE)\u0027].json.body || $node[\u0027LLM Analyze (SSE)\u0027].json.data || \u0027\u0027);\nconst chunks = rawBody.split(/\\r?\\n\\r?\\n/);\nlet merged = \u0027\u0027;\nfor (const c of chunks) {\n  const line = c.trim();\n  if (!line.startsWith(\u0027data:\u0027)) continue;\n  const payload = line.slice(5).trim();\n  if (payload === \u0027[DONE]\u0027) continue;\n  try {\n    const j = JSON.parse(payload);\n    const part = j?.choices?.[0]?.delta?.content || \u0027\u0027;\n    if (part) merged += part;\n  } catch {}\n}\n\n// Fallback: if response is plain JSON (not SSE), try direct parse.\nlet ai = { items: [] };\ntry {\n  ai = JSON.parse(merged);\n} catch {\n  try {\n    const direct = JSON.parse(rawBody);\n    const content = direct?.choices?.[0]?.message?.content || \u0027{}\u0027;\n    ai = JSON.parse(content);\n  } catch {\n    ai = { items: [] };\n  }\n}\n\nconst aiMap = new Map((ai.items || []).map(x =\u003e [String(x.source_id || \u0027\u0027), x]));\n\nconst records = original.slice(0, 200).map((x) =\u003e {\n  const sid = String(x.source_id || \u0027\u0027);\n  const isHn = sid.startsWith(\u0027hn:\u0027);\n  const hnId = isHn ? sid.replace(\u0027hn:\u0027, \u0027\u0027) : \u0027\u0027;\n  const m = aiMap.get(sid) || {};\n  return {\n    fields: {\n      title: String(x.title || \u0027\u0027),\n      url: String(x.url || \u0027\u0027),\n      score: Number(x.score || 0),\n      author: String(x.author || \u0027\u0027),\n      published_at: String(x.published_at || \u0027\u0027),\n      hn_comments: isHn ? `https://news.ycombinator.com/item?id=${hnId}` : \u0027\u0027,\n      source: String(x.source_name || x.source || \u0027\u0027),\n      summary_cn: String(m.summary_cn || \u0027\u0027),\n      tags: String(m.tags || \u0027\u0027),\n      stance: String(m.stance || \u0027\u0027)\n    }\n  };\n});\n\nreturn [{ json: { records, count: records.length, ai_raw_preview: merged.slice(0, 300) } }];"
                                     },
